def validar_vlan():
    print("--- Validador de Rangos VLAN ---")
    try:
        vlan = int(input("Ingrese el número de VLAN a consultar: "))
        
        # Rangos estándar de VLANs en Cisco
        if vlan == 1 or (vlan >= 2 and vlan <= 1005):
            print(f"La VLAN {vlan} corresponde al Rango Normal.")
        elif vlan >= 1006 and vlan <= 4094:
            print(f"La VLAN {vlan} corresponde al Rango Extendido.")
        elif vlan == 0 or vlan == 4095:
            print(f"La VLAN {vlan} es un ID reservado del sistema.")
        else:
            print("Número de VLAN inválido. Debe estar entre 1 y 4094.")
            
    except ValueError:
        print("Error: Por favor, ingrese un número entero válido.")

if __name__ == "__main__":
    validar_vlan()
